                	"hint":        ""
                },
                
                { 
                	"bindingName": "Tweak_N0", 
                	"label":       "Base", 
                	"widget":      "texture_group",
                	"sortIndex":   "0",
                	"hint":        ""
                },
                
                { 
                	"bindingName": "Tweak_N57", 
                	"label":       "Eyes Makeup Mask", 
                	"widget":      "texture_group",
                	"sortIndex":   "0",
                	"hint":        ""
                },
                
                {
                	"bindingName": "eyesMakeup",
                	"label":       "Eyes Makeup Alpha",
                	"widget":      "slider",
                	"min":         0,
                	"max":         1,
                	"step":        "0.01",
                	"sortIndex":   "0",
                	"hint":        "",
                	"default":     "1.0"
                },
                
                { 
                	"bindingName": "browsMask", 
                	"label":       "Brows Mask", 
                	"widget":      "texture_group",
                	"sortIndex":   "0",
                	"hint":        ""
                },
                
                {
                	"bindingName": "browsAlpha",
                	"label":       "Brows Alpha",
                	"widget":      "slider",
                	"min":         0,
                	"max":         1,
                	"step":        "0.01",
                	"sortIndex":   "0",
                	"hint":        "",
                	"default":     "1.0"
                },
                
                { 
                	"bindingName": "whiteningEyes", 
                	"label":       "Whitening Eyes", 
                	"widget":      "texture_group",
                	"sortIndex":   "0",
                	"hint":        ""
                },
                
                {
                	"bindingName": "WhiteningEyesAlpha",
                	"label":       "WhiteningEyes Alpha",
                	"widget":      "slider",
                	"min":         0,
